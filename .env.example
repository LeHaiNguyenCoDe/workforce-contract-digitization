# Application
APP_NAME="Workforce Contract Digitization"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=workforce
DB_USERNAME=root
DB_PASSWORD=

# Redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@workforce-contract.local
MAIL_FROM_NAME="${APP_NAME}"

# AWS (if using S3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug

# Session
SESSION_DRIVER=cookie
SESSION_LIFETIME=120

# Cache
CACHE_DRIVER=redis

# Queue
QUEUE_CONNECTION=redis

# Filesystem
FILESYSTEM_DRIVER=local

# API
API_PREFIX=api/v1

# JWT (if using JWT authentication)
JWT_SECRET=
JWT_ALGORITHM=HS256

# Staging specific
STAGING_APP_URL=http://staging.workforce-contract.local
STAGING_API_URL=http://staging.workforce-contract.local/api/v1

# Production specific
PRODUCTION_APP_URL=https://workforce-contract.com
PRODUCTION_API_URL=https://workforce-contract.com/api/v1

